@page "/s/{Slug}/complete"
@layout Layout.SurveyLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization

<PageTitle>제출 완료</PageTitle>

<div class="survey-public-page">
    <div class="survey-public-card survey-complete-card">
        <div class="survey-complete-icon">✓</div>
        <h1>설문이 제출되었습니다</h1>
        <p>소중한 의견 감사합니다.</p>
    </div>
</div>

@code {
    [Parameter]
    public string Slug { get; set; } = "";
}
