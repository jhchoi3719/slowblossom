@page "/admin/mail-notify"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using RotationDating.Web.Services.MailNotification
@inject MailNotificationSettingsProvider SettingsProvider
@inject MailNotificationStateStore StateStore

<PageTitle>신청 알림 (텔레그램)</PageTitle>

<div class="page">
    <header class="page-header">
        <a href="/home" class="back-link">← 메뉴</a>
        <h1>신청 알림</h1>
        <p class="subtitle">네이버폼 메일 수신 시 텔레그램으로 알림</p>
    </header>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert-success">@_message</div>
    }
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="error-text">@_error</div>
    }

    <section class="card-section">
        <h2>현재 상태</h2>
        <ul class="status-list">
            <li>기능 사용: @(_effective.Enabled ? "ON" : "OFF")@(_effective.EnabledOverriddenByEnv ? " (환경변수 우선)" : "")</li>
            <li>네이버 IMAP: @(_imapConfigured ? "설정됨" : "미설정")</li>
            <li>텔레그램: @(_telegramConfigured ? "설정됨" : "미설정")</li>
            <li>확인 주기: @(_effective.PollIntervalSeconds)초</li>
            <li>마지막 확인: @FormatUtc(_state.LastCheckedAtUtc)</li>
            <li>마지막 알림: @FormatUtc(_state.LastNotifiedAtUtc)</li>
            @if (!string.IsNullOrWhiteSpace(_state.LastNotifiedSubject))
            {
                <li>마지막 메일: @_state.LastNotifiedSubject</li>
            }
        </ul>
    </section>

    <section class="card-section">
        <h2>네이버 IMAP 설정</h2>
        <p class="form-help">
            네이버 메일 <strong>POP3/IMAP 사용</strong>을 켜고, 2단계 인증 사용 시 <strong>애플리케이션 비밀번호</strong>를 입력하세요.
        </p>
        @if (_effective.UsernameLockedByEnv || _effective.PasswordLockedByEnv || _effective.EnabledOverriddenByEnv)
        {
            <p class="form-help">
                Render 환경변수로 일부 IMAP 값이 고정되어 있습니다.
                @if (_effective.EnabledOverriddenByEnv)
                {
                    <span>실제 ON/OFF는 <strong>MAIL_NOTIFICATION_ENABLED</strong> 환경변수가 우선하지만, 아래 체크 상태는 저장됩니다.</span>
                }
            </p>
        }

        <form method="post" action="/admin/mail-notify/save" class="form-stack">
            <input type="hidden" name="enabled" value="false" />
            <label class="checkbox-label">
                @if (_form.Enabled)
                {
                    <input type="checkbox" name="enabled" value="true" checked="checked" />
                }
                else
                {
                    <input type="checkbox" name="enabled" value="true" />
                }
                신청 알림 사용
            </label>

            <label class="form-field">
                <span class="label">네이버 아이디</span>
                @if (_effective.UsernameLockedByEnv)
                {
                    <input type="hidden" name="username" value="@_effective.NaverImap.Username" />
                }
                <input type="text" name="username" class="input" value="@_form.Username" required disabled="@_effective.UsernameLockedByEnv" />
            </label>

            <label class="form-field">
                <span class="label">비밀번호 / 앱 비밀번호</span>
                <input type="password" name="password" class="input" placeholder="@(_hasSavedPassword ? "변경할 때만 입력" : "비밀번호 입력")" disabled="@_effective.PasswordLockedByEnv" autocomplete="new-password" />
            </label>

            <label class="form-field">
                <span class="label">메일 제목 필터</span>
                @if (_effective.SubjectLockedByEnv)
                {
                    <input type="hidden" name="subjectContains" value="@_effective.NaverImap.SubjectContains" />
                }
                <input type="text" name="subjectContains" class="input" value="@_form.SubjectContains" disabled="@_effective.SubjectLockedByEnv" />
                <span class="form-help">제목에 이 문구가 포함된 메일만 알림 (예: 네이버폼)</span>
            </label>

            <label class="form-field">
                <span class="label">발신자 필터 (선택)</span>
                @if (_effective.FromFilterLockedByEnv)
                {
                    <input type="hidden" name="fromFilter" value="@_effective.NaverImap.FromFilter" />
                }
                <input type="text" name="fromFilter" class="input" value="@_form.FromFilter" disabled="@_effective.FromFilterLockedByEnv" placeholder="예: naver.com" />
            </label>

            <label class="form-field">
                <span class="label">확인 주기 (초)</span>
                <input type="number" name="pollIntervalSeconds" class="input" value="@_form.PollIntervalSeconds" min="30" max="600" />
            </label>

            <button type="submit" class="btn btn-primary">IMAP 설정 저장</button>
        </form>
    </section>

    <section class="card-section">
        <h2>텔레그램 설정</h2>
        <p class="form-help">
            1. 텔레그램에서 <strong>@@BotFather</strong> → <code>/newbot</code> → Bot Token 발급<br />
            2. 만든 봇에게 <strong>/start</strong> 메시지 전송<br />
            3. 브라우저에서 <code>https://api.telegram.org/bot&lt;토큰&gt;/getUpdates</code> 열어 <strong>chat.id</strong> 확인
        </p>
        @if (_effective.TelegramBotTokenLockedByEnv || _effective.TelegramChatIdLockedByEnv)
        {
            <p class="form-help">Render 환경변수로 일부 텔레그램 값이 고정되어 있습니다.</p>
        }

        <form method="post" action="/admin/mail-notify/save-telegram" class="form-stack">
            <label class="form-field">
                <span class="label">Bot Token</span>
                <input type="text" name="botToken" class="input" value="@_form.TelegramBotToken" required disabled="@_effective.TelegramBotTokenLockedByEnv" autocomplete="off" />
            </label>

            <label class="form-field">
                <span class="label">Chat ID</span>
                <input type="text" name="chatId" class="input" value="@_form.TelegramChatId" required disabled="@_effective.TelegramChatIdLockedByEnv" placeholder="예: 123456789" />
            </label>

            <button type="submit" class="btn btn-primary">텔레그램 설정 저장</button>
        </form>

        <div class="toolbar toolbar-actions" style="margin-top: 1rem;">
            <form method="post" action="/admin/mail-notify/test" class="inline-form">
                <button type="submit" class="btn btn-secondary">테스트 메시지 보내기</button>
            </form>
            <form method="post" action="/admin/mail-notify/check-now" class="inline-form">
                <button type="submit" class="btn btn-secondary">지금 메일 확인</button>
            </form>
        </div>
        <p class="form-help">「지금 메일 확인」은 받은 메일 중 가장 최근 <strong>[네이버 폼]</strong> 제목 메일을 텔레그램으로 보냅니다.</p>
    </section>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Sent { get; set; }

    [SupplyParameterFromQuery]
    public string? Checked { get; set; }

    [SupplyParameterFromQuery]
    public string? Saved { get; set; }

    [SupplyParameterFromQuery]
    public string? SavedTelegram { get; set; }

    [SupplyParameterFromQuery]
    public string? Detail { get; set; }

    private MailNotificationEffectiveSettings _effective = new();
    private MailNotificationStoredSettings _form = new();
    private MailNotificationState _state = new();
    private bool _imapConfigured;
    private bool _telegramConfigured;
    private bool _hasSavedPassword;
    private string _message = "";
    private string _error = "";

    protected override async Task OnInitializedAsync()
    {
        _effective = await SettingsProvider.GetEffectiveSettingsAsync();
        _form = await SettingsProvider.GetStoredSettingsAsync();
        _state = await StateStore.LoadAsync();
        _hasSavedPassword = !string.IsNullOrWhiteSpace(_form.Password);
        _imapConfigured = !string.IsNullOrWhiteSpace(_effective.NaverImap.Username)
            && !string.IsNullOrWhiteSpace(_effective.NaverImap.Password);
        _telegramConfigured = !string.IsNullOrWhiteSpace(_effective.Telegram.BotToken)
            && !string.IsNullOrWhiteSpace(_effective.Telegram.ChatId);

        if (string.IsNullOrWhiteSpace(_form.TelegramBotToken) && !string.IsNullOrWhiteSpace(_effective.Telegram.BotToken))
            _form.TelegramBotToken = _effective.Telegram.BotToken;
        if (string.IsNullOrWhiteSpace(_form.TelegramChatId) && !string.IsNullOrWhiteSpace(_effective.Telegram.ChatId))
            _form.TelegramChatId = _effective.Telegram.ChatId;

        if (Saved == "1")
            _message = $"IMAP 설정이 저장되었습니다. (신청 알림: {(_form.Enabled ? "ON" : "OFF")})";
        else if (SavedTelegram == "1")
            _message = "텔레그램 설정이 저장되었습니다.";
        else if (Sent == "1")
            _message = "테스트 메시지를 보냈습니다.";
        else if (Checked == "1")
            _message = string.IsNullOrWhiteSpace(Detail)
                ? "가장 최근 [네이버 폼] 메일 알림을 보냈습니다."
                : $"알림 전송: {Detail}";

        _error = Error switch
        {
            "noTelegram" => "텔레그램 Bot Token과 Chat ID를 저장한 뒤 다시 시도하세요.",
            "noMail" => Detail ?? "제목이 [네이버 폼]으로 시작하는 메일이 없습니다.",
            "send" => $"텔레그램 메시지 전송 실패: {Detail ?? "봇에게 /start를 보냈는지, Chat ID가 맞는지 확인하세요."}",
            "imap" => "메일 확인에 실패했습니다. IMAP 설정을 확인하세요.",
            "save" => "네이버 아이디는 필수입니다.",
            "saveTelegram" => "Bot Token과 Chat ID는 필수입니다.",
            _ => ""
        };
    }

    private static string FormatUtc(DateTime? value) =>
        value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-";
}
