@page "/"
@layout Layout.LoginLayout
@using RotationDating.Web.Services

<PageTitle>로그인</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-brand">
            <img src="logo.png" alt="slow blossom" class="login-logo-img" />
        </div>

        <div class="login-content">
            <p class="login-message">이름 + 행사일(YYMMDD) + 패스워드로 로그인하세요</p>
            <p class="login-example">예: @_exampleDateLabel 행사 참가 홍길동 → <strong>@_exampleLoginId</strong></p>

            <form method="post" action="/login" class="login-form" enctype="application/x-www-form-urlencoded">
                <AntiforgeryToken />
                <input type="text"
                       name="username"
                       class="input login-input"
                       placeholder="@_exampleLoginId"
                       autocomplete="username"
                       required
                       maxlength="50" />
                <input type="password"
                       name="password"
                       class="input login-input"
                       placeholder="4자리 패스워드 (최초 로그인 시 생략)"
                       autocomplete="current-password"
                       inputmode="numeric"
                       pattern="\d{4}"
                       maxlength="4" />
                <button type="submit" class="btn btn-primary login-btn">로그인</button>
            </form>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <p class="error-text login-error">@_errorMessage</p>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private string _errorMessage => Error switch
    {
        "password" => "패스워드가 일치하지 않습니다.",
        "required" => "패스워드를 입력해 주세요.",
        "session" => "로그인 정보가 만료되었습니다. 다시 로그인해 주세요.",
        _ => ""
    };

    private string _exampleDateLabel => DateTime.Today.ToString("M월 d일");
    private string _exampleLoginId => ParticipantAuthService.FormatLoginId("홍길동", DateTime.Today);
}
