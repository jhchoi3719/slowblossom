@page "/set-password"
@layout Layout.LoginLayout
@using RotationDating.Web.Services
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

<PageTitle>패스워드 설정</PageTitle>

@if (_sessionValid)
{
<div class="login-page">
    <div class="login-card">
        <div class="login-brand">
            <img src="logo.png" alt="slow blossom" class="login-logo-img" />
        </div>

        <div class="login-content">
            <p class="login-message">패스워드를 설정하세요</p>
            <p class="login-example">다음 로그인부터 <strong>이름+행사일+패스워드</strong>로 로그인합니다.</p>

            <form method="post" action="/set-password" class="login-form" enctype="application/x-www-form-urlencoded">
                <AntiforgeryToken />
                <input type="password"
                       name="password"
                       class="input login-input"
                       placeholder="4자리 패스워드"
                       autocomplete="new-password"
                       inputmode="numeric"
                       pattern="\d{4}"
                       maxlength="4"
                       required />
                <button type="submit" class="btn btn-primary login-btn">설정 완료</button>
            </form>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <p class="error-text login-error">@_errorMessage</p>
            }
        </div>
    </div>
</div>
}

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private bool _sessionValid;

    protected override void OnInitialized()
    {
        var applicationId = HttpContextAccessor.HttpContext is { } ctx
            ? ParticipantPasswordSetupStore.GetPendingApplicationId(ctx)
            : null;

        if (applicationId is null)
            Navigation.NavigateTo(Error == "session" ? "/?error=session" : "/", replace: true);
        else
            _sessionValid = true;
    }

    private string _errorMessage => Error switch
    {
        "format" => "4자리 숫자 패스워드를 입력해 주세요.",
        "session" => "로그인 정보가 만료되었습니다. 다시 로그인해 주세요.",
        _ => ""
    };
}
